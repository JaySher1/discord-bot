DISCORD_TOKEN=put-your-bot-token-here
DISCORD_CLIENT_ID=put-your-application-client-id-here

# Recommended while building/testing. Guild commands update almost instantly.
DISCORD_GUILD_ID=put-your-test-server-id-here

# Optional defaults. You can also configure these with slash commands.
DEFAULT_WELCOME_CHANNEL_ID=
DEFAULT_LOG_CHANNEL_ID=

# Lavalink music playback. For same-server Droplet setup, use 127.0.0.1.
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=change-this-password
LAVALINK_SECURE=false
