{
  "name": "server-command-discord-bot",
  "version": "1.0.0",
  "description": "A TypeScript Discord.js bot with moderation, welcome messages, games, utilities, and server configuration.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "db:init": "tsx src/scripts/init-db.ts",
    "deploy": "node dist/deploy-commands.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "keywords": [
    "discord",
    "bot",
    "discord.js",
    "typescript",
    "moderation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.19.3",
    "dotenv": "^16.5.0",
    "ffmpeg-static": "^5.3.0",
    "libsodium-wrappers": "^0.8.4",
    "opusscript": "^0.0.8",
    "play-dl": "^1.9.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
